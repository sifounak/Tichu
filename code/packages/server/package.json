{
  "name": "@tichu/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "@tichu/shared": "workspace:*",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^11.0.0",
    "drizzle-orm": "^0.45.1",
    "fastify": "^5.2.0",
    "jsonwebtoken": "^9.0.3",
    "ws": "^8.18.0",
    "xstate": "^5.28.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ws": "^8.5.0",
    "@vitest/coverage-v8": "^3.0.0",
    "drizzle-kit": "^0.31.9",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
