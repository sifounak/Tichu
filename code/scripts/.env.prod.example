# Tichu production environment variables
#
# Place this file in the PARENT of your deploy target directory. For example,
# if you deploy to /files/.www/tichu/built/, place this at /files/.www/tichu/.env.prod
#
# Create from template:
#   cp .env.prod.example /files/.www/tichu/.env.prod
#   nano /files/.www/tichu/.env.prod
#
# This file is sourced by prod-build.sh (for NEXT_PUBLIC_* build-time vars)
# and referenced by the systemd EnvironmentFile directive (for server runtime vars).

# ─── Server ─────────────────────────────────────────────────────────────
# REQUIRED: Secret key for signing JWT auth tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Port the Fastify game server listens on (default: 3001)
PORT=3001

# Origin allowed to make API/WebSocket requests (your domain with https)
CORS_ORIGIN=https://sifounakis.com

# Absolute path to the SQLite database file.
# Should point to the persistent data/ directory alongside .env.prod.
DATABASE_PATH=/files/.www/tichu/data/tichu.sqlite

# ─── Client (NEXT_PUBLIC_* vars are baked into the Next.js build) ────────
# WebSocket URL the browser connects to (wss:// for HTTPS sites)
NEXT_PUBLIC_WS_URL=wss://sifounakis.com/tichu/ws

# HTTP API URL the browser uses for auth, stats, etc.
NEXT_PUBLIC_API_URL=https://sifounakis.com/tichu/api

# Base path where the app is served (must match Apache proxy config)
NEXT_PUBLIC_BASE_PATH=/tichu
