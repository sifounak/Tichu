# Tichu production environment variables
# Copy this file to .env.prod and fill in your values:
#   cp .env.prod.example .env.prod
#
# This file is sourced by prod-build.sh and the systemd service files.

# ─── Server ─────────────────────────────────────────────────────────────
# REQUIRED: Secret key for signing JWT auth tokens.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Port the Fastify game server listens on (default: 3001)
PORT=3001

# Origin allowed to make API/WebSocket requests (your domain with https)
CORS_ORIGIN=https://sifounakis.com

# Path to the SQLite database file (relative to server package directory)
DATABASE_PATH=./data/tichu.sqlite

# ─── Client (NEXT_PUBLIC_* vars are baked into the Next.js build) ────────
# WebSocket URL the browser connects to (wss:// for HTTPS sites)
NEXT_PUBLIC_WS_URL=wss://sifounakis.com/tichu/ws

# HTTP API URL the browser uses for auth, stats, etc.
NEXT_PUBLIC_API_URL=https://sifounakis.com/tichu/api

# Base path where the app is served (must match Apache proxy config)
NEXT_PUBLIC_BASE_PATH=/tichu
