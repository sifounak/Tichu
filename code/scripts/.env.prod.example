# Production environment variables
# Copy to .env.prod and fill in real values:
#   cp .env.prod.example .env.prod
#
# .env.prod is gitignored — never commit it with real secrets.

# Client (build-time — NEXT_PUBLIC_ prefix required by Next.js)
NEXT_PUBLIC_WS_URL=wss://sifounakis.com/tichu/ws
NEXT_PUBLIC_API_URL=https://sifounakis.com/tichu/api
NEXT_PUBLIC_BASE_PATH=/tichu

# Server (runtime)
PORT=3001
CORS_ORIGIN=https://sifounakis.com
DATABASE_PATH=/files/.www/tichu_source/code/packages/server/data/tichu.sqlite
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_SECRET
